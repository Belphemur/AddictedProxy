# syntax=docker/dockerfile:1
# Development image for the Nuxt frontend.
# Source is expected to be bind-mounted at /app from the host, so this image
# only installs the package manager and dependencies.  Hot-module replacement
# and Nuxt devtools work because the source files are on the host filesystem.

FROM node:24-alpine

# Install corepack so the pnpm version declared in package.json is used exactly.
RUN npm i -g corepack@latest && corepack enable pnpm

WORKDIR /app

# Copy only the manifest files first so the dependency layer is cached
# independently from source changes.
COPY package.json pnpm-lock.yaml ./

# Install dependencies into the image layer.
# The actual source is bind-mounted at runtime, so this is just a warm cache.
RUN pnpm install --frozen-lockfile

EXPOSE 3000

# `pnpm dev --host` binds to 0.0.0.0 so the port is reachable outside the container.
CMD ["pnpm", "dev", "--host"]
